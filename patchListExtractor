# 팩토리 목록 (소스에서 직접 관리)
BONSA_FACTORIES = ["M10", "M11", "M12", "M13", "M14", "M16"]
WUSI_FACTORIES  = ["C2"]

TARGET_EXTENSIONS  = (".java", ".cs")
DIFF_CONTEXT_LINES = 10


# =========================================================
# 2. 정규표현식
# =========================================================
# getFabUseYn("팹코드", ...) → 첫 번째 인자만 캡처 (인자 수 무관)
FABUSE_REGEX = re.compile(
    r"getFabUseYn\s*\(\s*\"([^\"]+)\""
)

# getFabOrientedUseYn("catgCd", "difCd", factory) → 1·2번째 인자만 캡처
FABDIF_REGEX = re.compile(
    r"getFabOrientedUseYn\s*\(\s*\"([^\"]+)\"\s*,\s*\"([^\"]+)\"\s*,\s*[^)]+\)"
)


# =========================================================
# 3. DB 쿼리
# =========================================================
QUERY_FABUSE = """
    SELECT useYn
    FROM biz_fabfunc_det
    WHERE fac_id = 'OMES'
      AND func_cd_lval = :fabUseYnValue
"""

QUERY_FABDIF = """
    SELECT factory, useYn
    FROM omes_fabdif_det
    WHERE catg_cd = :catgCd
      AND dif_cd  = :difCd
"""


# =========================================================
# 4. Oracle Client 초기화 (프로세스당 1회)
# =========================================================
_oracle_client_initialized = False


def _find_oracle_client_lib():
    for p in os.environ.get("PATH", "").split(";"):
        if os.path.exists(os.path.join(p.strip(), "oci.dll")):
            return None
    patterns = [
        r"C:\oracle\instantclient*",
        r"C:\instantclient*",
        r"C:\oracle\product\*\client_1\bin",
        r"C:\app\*\product\*\client_1\bin",
        r"C:\Program Files\Oracle\instantclient*",
    ]
    for pattern in patterns:
        for match in sorted(glob.glob(pattern), reverse=True):
            if os.path.exists(os.path.join(match, "oci.dll")):
                return match
    return None


def _init_oracle_client():
    global _oracle_client_initialized
    if _oracle_client_initialized:
        return
    lib_dir = _find_oracle_client_lib()
    if lib_dir:
        oracledb.init_oracle_client(lib_dir=lib_dir)
    else:
        oracledb.init_oracle_client()
    _oracle_client_initialized = True


def get_connection(db_config):
    _init_oracle_client()
    dsn = oracledb.makedsn(
        db_config["host"],
        db_config["port"],
        sid=db_config["service"],
    )
    return oracledb.connect(
        user=db_config["user"],
        password=db_config["password"],
        dsn=dsn,
    )


# =========================================================
# 5. Git 관련 함수
# =========================================================
def _resolve_diff_range(from_commit, to_commit):
    """from == to 이면 단일 커밋 조회로 자동 전환"""
    if from_commit == to_commit:
        return f"{to_commit}~1..{to_commit}"
    return f"{from_commit}..{to_commit}"


def get_changed_files(repo_path, branch, from_commit, to_commit):
    repo = git.Repo(repo_path)
    diff_range = _resolve_diff_range(from_commit, to_commit)
    diff_index = repo.git.diff("--name-only", diff_range)
    files = [f for f in diff_index.splitlines() if f.strip()]
    files = [f for f in files if f.lower().endswith(TARGET_EXTENSIONS)]
    return repo, files


def get_file_content_at_commit(repo, commit, filepath):
    try:
        return repo.git.show(f"{commit}:{filepath}")
    except git.exc.GitCommandError:
        return None


def get_changed_content(repo, from_commit, to_commit, filepath):
    diff_range = _resolve_diff_range(from_commit, to_commit)
    try:
        diff_text = repo.git.diff(
            f"-U{DIFF_CONTEXT_LINES}", diff_range, "--", filepath
        )
    except git.exc.GitCommandError:
        return None
    if not diff_text:
        return None
    kept = []
    for line in diff_text.splitlines():
        if line.startswith(("+++", "---", "@@", "diff ", "index ")):
            continue
        if line.startswith("-"):
            continue
        if line.startswith("+"):
            kept.append(line[1:])
        elif line.startswith(" "):
            kept.append(line[1:])
    return "\n".join(kept) if kept else None


def get_last_author(repo, from_commit, to_commit, filepath):
    diff_range = _resolve_diff_range(from_commit, to_commit)
    try:
        log = repo.git.log(diff_range, "--format=%an", "--", filepath)
        authors = [a for a in log.splitlines() if a.strip()]
        if authors:
            return authors[0]
    except git.exc.GitCommandError:
        pass
    return "Unknown"


# =========================================================
# 6. 정규식 추출
# =========================================================
def extract_fabuse_calls(content):
    if not content:
        return []
    return [m.group(1) for m in FABUSE_REGEX.finditer(content)]


def extract_fabdif_calls(content, filepath):
    if not content:
        return []
    return [(m.group(1), m.group(2)) for m in FABDIF_REGEX.finditer(content)]


# =========================================================
# 7. DB 조회
# =========================================================
def query_fabuse(conn, value):
    cur = conn.cursor()
    cur.execute(QUERY_FABUSE, fabUseYnValue=value)
    row = cur.fetchone()
    cur.close()
    return row[0] if (row and row[0] is not None) else "X"


def query_fabdif(conns, catg_cd, dif_cd, active_factories):
    """
    conns: {"bonsa": conn, "wusi": conn} 활성화된 것만 포함
    active_factories: 현재 조회할 팩토리 목록
    반환: {factory: Y/N/X}
    """
    result = {f: "X" for f in active_factories}

    if "bonsa" in conns:
        cur = conns["bonsa"].cursor()
        cur.execute(QUERY_FABDIF, catgCd=catg_cd, difCd=dif_cd)
        for factory, use_yn in cur.fetchall():
            if factory in result:
                result[factory] = use_yn if use_yn is not None else "X"
        cur.close()

    if "wusi" in conns:
        cur = conns["wusi"].cursor()
        cur.execute(QUERY_FABDIF, catgCd=catg_cd, difCd=dif_cd)
        for factory, use_yn in cur.fetchall():
            if factory in result:
                result[factory] = use_yn if use_yn is not None else "X"
        cur.close()

    return result


# =========================================================
# 8. 메인 분석 로직
# =========================================================
def analyze(repo_path, branch, from_commit, to_commit,
            scan_mode, use_bonsa, use_wusi, progress_cb=None):
    """
    반환: (rows, active_factories)
    중복 제거: fabUse는 value 기준, fabDif는 (catgCd, difCd) 기준
    """
    repo, files = get_changed_files(repo_path, branch, from_commit, to_commit)

    active_factories = []
    if use_bonsa:
        active_factories += BONSA_FACTORIES
    if use_wusi:
        active_factories += WUSI_FACTORIES

    conns = {}
    if use_bonsa:
        conns["bonsa"] = get_connection(DB_CONFIG_BONSA)
    if use_wusi:
        conns["wusi"] = get_connection(DB_CONFIG_WUSI)

    # fabUse용 연결 (본사 우선, 없으면 우시)
    fabuse_conn = conns.get("bonsa") or conns.get("wusi")

    rows = []
    seen_fabuse = set()
    seen_fabdif = set()

    try:
        total = len(files)
        for idx, filepath in enumerate(files):
            if progress_cb:
                progress_cb(idx + 1, total, filepath)

            content = (
                get_changed_content(repo, from_commit, to_commit, filepath)
                if scan_mode == "diff"
                else get_file_content_at_commit(repo, to_commit, filepath)
            )
            if content is None:
                continue

            author       = get_last_author(repo, from_commit, to_commit, filepath)
            fabuse_calls = extract_fabuse_calls(content)
            fabdif_calls = extract_fabdif_calls(content, filepath)

            if not fabuse_calls and not fabdif_calls:
                continue

            for value in fabuse_calls:
                if value in seen_fabuse:
                    continue
                seen_fabuse.add(value)
                yn = query_fabuse(fabuse_conn, value) if fabuse_conn else "X"
                rows.append({
                    "file":            filepath,
                    "author":          author,
                    "call_type":       "fabUse",
                    "fabuse_value":    value,
                    "fabuse_yn":       yn,
                    "catg_cd":         "",
                    "dif_cd":          "",
                    "factory_results": {},
                })

            for catg_cd, dif_cd in fabdif_calls:
                key = (catg_cd, dif_cd)
                if key in seen_fabdif:
                    continue
                seen_fabdif.add(key)
                factory_results = query_fabdif(conns, catg_cd, dif_cd, active_factories)
                rows.append({
                    "file":            filepath,
                    "author":          author,
                    "call_type":       "fabDif",
                    "fabuse_value":    "",
                    "fabuse_yn":       "",
                    "catg_cd":         catg_cd,
                    "dif_cd":          dif_cd,
                    "factory_results": factory_results,
                })
    finally:
        for conn in conns.values():
            try:
                conn.close()
            except Exception:
                pass

    return rows, active_factories


