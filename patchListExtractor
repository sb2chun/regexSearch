    def _rebuild_trees(self, active_factories):
        """조회 실행마다 팩토리 컬럼이 달라지므로 트리를 재생성."""
        # 기존 위젯 제거
        for widget in self._tree_new_frame.winfo_children():
            widget.destroy()
        for widget in self._tree_exist_frame.winfo_children():
            widget.destroy()

        columns = (["file", "author", "type",
                    "fabuse_value", "fabuse_yn",
                    "catg_cd", "dif_cd"] + active_factories)
        headers = {
            "file":         "파일명",
            "author":       "Merge개발자",
            "type":         "구분",
            "fabuse_value": "FabUseVal",
            "fabuse_yn":    "FabUseYn",
            "catg_cd":      "CatgCd",
            "dif_cd":       "DifCd",
        }
        for f in active_factories:
            headers[f] = f

        self.tree_new   = self._make_tree(self._tree_new_frame,   columns, headers)
        self.tree_exist = self._make_tree(self._tree_exist_frame, columns, headers)
        self.tree_new.tag_configure("has_x", background="#ffd6d6")

    def _make_tree(self, parent, columns, headers):
        frm = ttk.Frame(parent)
        frm.pack(fill="both", expand=True)

        tree = ttk.Treeview(frm, columns=columns, show="headings",
                             height=7, selectmode="extended")
        for col in columns:
            tree.heading(col, text=headers[col])
            w = 160 if col == "file" else 80 if col in ("fabuse_value",) else 65
            tree.column(col, width=w, anchor="center", minwidth=40)

        vsb = ttk.Scrollbar(frm, orient="vertical",   command=tree.yview)
        hsb = ttk.Scrollbar(frm, orient="horizontal", command=tree.xview)
        tree.configure(yscrollcommand=vsb.set, xscrollcommand=hsb.set)

        tree.grid(row=0, column=0, sticky="nsew")
        vsb.grid(row=0, column=1, sticky="ns")
        hsb.grid(row=1, column=0, sticky="ew")
        frm.rowconfigure(0, weight=1)
        frm.columnconfigure(0, weight=1)

        # Ctrl+C 복사 바인딩
        tree.bind("<Control-c>", lambda e: self._copy_selected(tree))
        # 우클릭 컨텍스트 메뉴
        menu = tk.Menu(tree, tearoff=0)
        menu.add_command(label="복사 (Ctrl+C)", command=lambda: self._copy_selected(tree))
        tree.bind("<Button-3>", lambda e: menu.post(e.x_root, e.y_root))

        return tree

