# -*- coding: utf-8 -*-
"""
FabUseYn / FabDif 커밋 범위 조회 도구
====================================
pip install GitPython python-oracledb 설치

특정 git 브랜치의 from~to 커밋 사이에 변경된 파일들을 (to 커밋 시점 기준) 전체 스캔하여
getFabUseYn(...) / getFabOriented(...) / selectFabOriented(...) 호출을 정규식으로 추출하고,
Oracle DB에 해당 값이 등록되어 있는지 조회해서 보여주는 도구입니다.

전제:
- 변경 탐지 방식: A (변경 파일 "전체"를 to 커밋 시점 기준으로 스캔. 변경 라인 한정 아님)
  -> DB에 값이 없으면(X) = 아직 운영 DB에 미반영된 "신규 등록 후보"라는 의미로 사용.
- merge 개발자: 해당 파일을 마지막으로 수정(commit)한 사람을 표시 (PR/merge 커밋 author 기준)
- DB: Oracle (python-oracledb, thin mode 사용 - Oracle client 설치 불필요)

★★★ 본인 환경에 맞게 꼭 수정해야 하는 부분 ★★★
  1) DB_CONFIG (TNS 접속정보)
  2) FACTORY_LIST (M10~M16, C2 등 실제 팩토리 코드 목록)
  3) FABUSE_REGEX / FABDIF_REGEX (실제 함수명이 조금 다를 수 있다고 하셨으니 확인 후 조정)
  4) SQL 쿼리문 (QUERY_FABUSE / QUERY_FABDIF)
  5) GIT_REPO_PATH 기본값
"""

import os
import re
import csv
import threading
import tkinter as tk
from tkinter import ttk, filedialog, messagebox

import git  # pip install GitPython
import oracledb  # pip install python-oracledb


# =========================================================
# 1. 환경 설정 - 본인 환경에 맞게 수정하세요
# =========================================================

# Git 로컬 저장소 경로 (Sourcetree에서 클론해둔 경로)
GIT_REPO_PATH_DEFAULT = r"C:\git\your_repo"

# Oracle DB 접속 정보 (TNS) - 본인 운영DB 정보로 교체
DB_CONFIG = {
    "user": "DB_USER",
    "password": "DB_PASSWORD",
    "dsn": "host:1521/service_name",  # 예: "10.10.10.10:1521/ORCLPDB"
}

# FabDif 결과를 보여줄 팩토리 목록 (컬럼 순서대로 출력됨)
FACTORY_LIST = ["M10", "M11", "M12", "M13", "M14", "M16", "C2"]

# 스캔 대상 소스 확장자
TARGET_EXTENSIONS = (".java", ".cs")

# =========================================================
# 2. 정규표현식 - 함수명이 상이할 수 있다고 하셨으니 실제 소스 보고 조정 필요
# =========================================================
# 그룹: factory, fabUseYnValue (순서 고정이라고 가정. 다르면 조정)
FABUSE_REGEX = re.compile(
    r"getFabUseYn\s*\(\s*([A-Za-z0-9_\.\"]+)\s*,\s*\"([^\"]+)\"\s*\)"
)

# getFabOriented / selectFabOriented 둘 다 매칭. 인자 3개를 통째로 캡쳐 후
# 언어(java/cs)별로 인자 순서가 다르다고 하셨으므로 파일 확장자 기준으로 후처리에서 매핑.
FABDIF_REGEX = re.compile(
    r"(getFabOriented|selectFabOriented)\s*\(\s*([^)]+?)\s*\)"
)

# =========================================================
# 3. DB 쿼리 - 본인이 직접 수정한다고 하셨으니 자리만 맞춰둠
# =========================================================
QUERY_FABUSE = """
    SELECT useYn
    FROM biz_fabfunc_det
    WHERE fac_id = 'OMES'
      AND func_cd_lval = :fabUseYnValue
"""

# factory별로 한 줄씩 나오게. factory 컬럼명은 실제 테이블 컬럼명으로 수정 필요 (예: fac_id, factory 등)
QUERY_FABDIF = """
    SELECT factory, useYn
    FROM omes_fabdif_det
    WHERE catg_cd = :catgCd
      AND dif_cd = :difCd
"""


# =========================================================
# 4. Git 관련 함수
# =========================================================
def get_changed_files(repo_path, branch, from_commit, to_commit):
    """from~to 사이 변경된 파일 목록 (대상 확장자만)"""
    repo = git.Repo(repo_path)
    diff_index = repo.git.diff("--name-only", f"{from_commit}..{to_commit}")
    files = [f for f in diff_index.splitlines() if f.strip()]
    files = [f for f in files if f.lower().endswith(TARGET_EXTENSIONS)]
    return repo, files


def get_file_content_at_commit(repo, commit, filepath):
    """특정 커밋 시점의 파일 전체 내용"""
    try:
        return repo.git.show(f"{commit}:{filepath}")
    except git.exc.GitCommandError:
        # 파일이 해당 커밋에서 삭제된 경우 등
        return None


# 변경 라인 앞뒤로 몇 줄을 컨텍스트로 포함할지 (멀티라인 함수 호출 누락 방지용)
DIFF_CONTEXT_LINES = 10


def get_changed_content(repo, from_commit, to_commit, filepath):
    """
    B안: from~to 사이 diff에서 '추가된(+) 라인 + 앞뒤 컨텍스트'만 모아서 반환.
    삭제(-)된 라인은 제외 (to 커밋 시점 기준 텍스트가 아니므로).
    diff 자체에 컨텍스트(-U)가 포함되어 있으므로 그 안의 +라인과 컨텍스트(공백 시작) 라인을 모두 모음.
    """
    try:
        diff_text = repo.git.diff(
            f"-U{DIFF_CONTEXT_LINES}",
            f"{from_commit}..{to_commit}",
            "--",
            filepath,
        )
    except git.exc.GitCommandError:
        return None

    if not diff_text:
        return None

    kept_lines = []
    for line in diff_text.splitlines():
        if line.startswith(("+++", "---", "@@", "diff ", "index ")):
            continue
        if line.startswith("-"):
            continue  # 삭제된 라인은 제외 (변경 후 시점 기준이 아님)
        if line.startswith("+"):
            kept_lines.append(line[1:])
        elif line.startswith(" "):
            kept_lines.append(line[1:])  # 컨텍스트 라인
    return "\n".join(kept_lines) if kept_lines else None


def get_last_author(repo, from_commit, to_commit, filepath):
    """from~to 범위에서 해당 파일을 마지막으로 수정한 커밋의 author(merge 개발자로 간주)"""
    try:
        log = repo.git.log(
            f"{from_commit}..{to_commit}",
            "--format=%an",
            "--",
            filepath,
        )
        authors = [a for a in log.splitlines() if a.strip()]
        if authors:
            return authors[0]  # 가장 최근(첫 줄) author
    except git.exc.GitCommandError:
        pass
    return "Unknown"


# =========================================================
# 5. 정규식 추출 함수
# =========================================================
def extract_fabuse_calls(content):
    """[(factory, fabUseYnValue), ...]"""
    if not content:
        return []
    return [(m.group(1), m.group(2)) for m in FABUSE_REGEX.finditer(content)]


def extract_fabdif_calls(content, filepath):
    """
    [(catgCd, difCd), ...]
    언어별 인자 순서:
      C#  selectFabOriented(factory, catgCd, difCd)
      JAVA getFabOriented(catgCd, difCd, factory)
          selectFabOriented(factory, catgCd, difCd)  <- java에도 selectFabOriented 있을 수 있다고 하셨음
    -> 함수명이 getFabOriented면 java식(catg, dif, factory) / selectFabOriented면 (factory, catg, dif)로 가정.
       실제 소스 확인 후 아래 매핑 로직만 바꾸면 됩니다.
    """
    if not content:
        return []

    results = []
    for m in FABDIF_REGEX.finditer(content):
        func_name = m.group(1)
        raw_args = m.group(2)
        # 인자 분리 (단순 split, 중첩 괄호/콤마 있는 복잡한 식은 추가 처리 필요)
        args = [a.strip().strip('"') for a in raw_args.split(",")]
        if len(args) != 3:
            continue  # 예상 인자 개수 아니면 스킵 (필요시 로그 남기도록 확장 가능)

        if func_name == "getFabOriented":
            # catgCd, difCd, factory
            catg_cd, dif_cd, _factory = args
        else:  # selectFabOriented
            # factory, catgCd, difCd
            _factory, catg_cd, dif_cd = args

        results.append((catg_cd, dif_cd))
    return results


# =========================================================
# 6. DB 조회 함수
# =========================================================
def get_connection():
    return oracledb.connect(
        user=DB_CONFIG["user"],
        password=DB_CONFIG["password"],
        dsn=DB_CONFIG["dsn"],
    )


def query_fabuse(conn, fab_use_yn_value):
    """반환: 'Y' / 'N' / 'X'(없음)"""
    cur = conn.cursor()
    cur.execute(QUERY_FABUSE, fabUseYnValue=fab_use_yn_value)
    row = cur.fetchone()
    cur.close()
    if row is None:
        return "X"
    return row[0] if row[0] is not None else "X"


def query_fabdif(conn, catg_cd, dif_cd):
    """반환: {factory: 'Y'/'N'/'X', ...} - FACTORY_LIST 전체에 대해"""
    cur = conn.cursor()
    cur.execute(QUERY_FABDIF, catgCd=catg_cd, difCd=dif_cd)
    rows = cur.fetchall()
    cur.close()

    result = {f: "X" for f in FACTORY_LIST}
    for factory, use_yn in rows:
        if factory in result:
            result[factory] = use_yn if use_yn is not None else "X"
    return result


# =========================================================
# 7. 메인 분석 로직
# =========================================================
def analyze(repo_path, branch, from_commit, to_commit, scan_mode="full", progress_cb=None):
    """
    scan_mode: "full" (A안 - 파일 전체 스캔) or "diff" (B안 - 변경분만 스캔)
    return: list of dict rows
      {
        file, author,
        call_type: 'fabUse' or 'fabDif',
        fabuse_value, fabuse_yn,
        catg_cd, dif_cd, factory_results(dict)
      }
    """
    repo, files = get_changed_files(repo_path, branch, from_commit, to_commit)
    rows = []
    conn = get_connection()
    try:
        total = len(files)
        for idx, filepath in enumerate(files):
            if progress_cb:
                progress_cb(idx + 1, total, filepath)

            if scan_mode == "diff":
                content = get_changed_content(repo, from_commit, to_commit, filepath)
            else:
                content = get_file_content_at_commit(repo, to_commit, filepath)

            if content is None:
                continue

            author = get_last_author(repo, from_commit, to_commit, filepath)

            fabuse_calls = extract_fabuse_calls(content)
            fabdif_calls = extract_fabdif_calls(content, filepath)

            if not fabuse_calls and not fabdif_calls:
                continue  # fabUse/fabDif 없는 파일은 결과에서 제외

            for factory, value in fabuse_calls:
                yn = query_fabuse(conn, value)
                rows.append({
                    "file": filepath,
                    "author": author,
                    "call_type": "fabUse",
                    "fabuse_value": value,
                    "fabuse_yn": yn,
                    "catg_cd": "",
                    "dif_cd": "",
                    "factory_results": {},
                })

            for catg_cd, dif_cd in fabdif_calls:
                factory_results = query_fabdif(conn, catg_cd, dif_cd)
                rows.append({
                    "file": filepath,
                    "author": author,
                    "call_type": "fabDif",
                    "fabuse_value": "",
                    "fabuse_yn": "",
                    "catg_cd": catg_cd,
                    "dif_cd": dif_cd,
                    "factory_results": factory_results,
                })
    finally:
        conn.close()

    return rows


