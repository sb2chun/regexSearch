            "catg_cd":      "CatgCd (헤더클릭=복사)",
            "dif_cd":       "DifCd (헤더클릭=복사)",
        }
        for f in ALL_FACTORIES:
            self._headers[f] = f

        new_frame = ttk.LabelFrame(self.root, text="🔴 신규 등록 필요 (X 포함)  ※ 컬럼 헤더 클릭 시 해당 컬럼 전체 값 복사")
