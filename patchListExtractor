# 8. GUI
# =========================================================
class App:
    def __init__(self, root):
        self.root = root
        root.title("FabUseYn / FabDif 커밋 범위 조회 도구")
        root.geometry("1200x650")

        self.rows_data = []  # CSV export용 원본 데이터 보관

        self._build_input_frame()
        self._build_regex_info_frame()
        self._build_result_tree()
        self._build_bottom_frame()

    # ---------- 입력 영역 ----------
    def _build_input_frame(self):
        frm = ttk.LabelFrame(self.root, text="조회 조건")
        frm.pack(fill="x", padx=8, pady=6)

        ttk.Label(frm, text="Git 저장소 경로:").grid(row=0, column=0, sticky="e", padx=4, pady=4)
        self.repo_path_var = tk.StringVar(value=GIT_REPO_PATH_DEFAULT)
        ttk.Entry(frm, textvariable=self.repo_path_var, width=50).grid(row=0, column=1, padx=4, pady=4, columnspan=3, sticky="we")
        ttk.Button(frm, text="찾아보기", command=self._browse_repo).grid(row=0, column=4, padx=4, pady=4)

        ttk.Label(frm, text="브랜치명:").grid(row=1, column=0, sticky="e", padx=4, pady=4)
        self.branch_var = tk.StringVar(value="dev_main")
        ttk.Entry(frm, textvariable=self.branch_var, width=20).grid(row=1, column=1, sticky="w", padx=4, pady=4)

        ttk.Label(frm, text="From Commit:").grid(row=1, column=2, sticky="e", padx=4, pady=4)
        self.from_var = tk.StringVar()
        ttk.Entry(frm, textvariable=self.from_var, width=20).grid(row=1, column=3, sticky="w", padx=4, pady=4)

        ttk.Label(frm, text="To Commit:").grid(row=2, column=2, sticky="e", padx=4, pady=4)
        self.to_var = tk.StringVar()
        ttk.Entry(frm, textvariable=self.to_var, width=20).grid(row=2, column=3, sticky="w", padx=4, pady=4)

        self.run_btn = ttk.Button(frm, text="조회 실행", command=self._run_clicked)
        self.run_btn.grid(row=2, column=1, padx=4, pady=4, sticky="w")

        ttk.Label(frm, text="검색 범위:").grid(row=3, column=0, sticky="e", padx=4, pady=4)
        self.scan_mode_var = tk.StringVar(value="full")
        mode_frm = ttk.Frame(frm)
        mode_frm.grid(row=3, column=1, columnspan=3, sticky="w", padx=4, pady=4)
        ttk.Radiobutton(mode_frm, text="전체 검색 (A안 - 파일 전체)", variable=self.scan_mode_var, value="full").pack(side="left", padx=4)
        ttk.Radiobutton(mode_frm, text="변경점 검색 (B안 - 변경된 부분만)", variable=self.scan_mode_var, value="diff").pack(side="left", padx=4)

        self.status_var = tk.StringVar(value="대기 중")
        ttk.Label(frm, textvariable=self.status_var, foreground="blue").grid(row=4, column=0, columnspan=5, sticky="w", padx=4)

        for i in range(5):
            frm.columnconfigure(i, weight=1)

    # ---------- 정규식 안내 영역 ----------
    def _build_regex_info_frame(self):
        frm = ttk.LabelFrame(self.root, text="사용 중인 정규식 (참고용)")
        frm.pack(fill="x", padx=8, pady=4)
        ttk.Label(frm, text=f"fabUse : {FABUSE_REGEX.pattern}", font=("Consolas", 9)).pack(anchor="w", padx=6)
        ttk.Label(frm, text=f"fabDif : {FABDIF_REGEX.pattern}", font=("Consolas", 9)).pack(anchor="w", padx=6)

    # ---------- 결과 테이블 (신규 / 기등록 분리) ----------
    def _build_result_tree(self):
        columns = ["file", "author", "type", "fabuse_value", "fabuse_yn", "catg_cd", "dif_cd"] + FACTORY_LIST
        headers = {
            "file": "파일명", "author": "Merge개발자", "type": "구분",
            "fabuse_value": "FabUseVal", "fabuse_yn": "FabUseYn",
            "catg_cd": "CatgCd", "dif_cd": "DifCd",
        }
        for f in FACTORY_LIST:
            headers[f] = f

        # 상단: 신규 등록 필요 (X 포함)
        new_frame = ttk.LabelFrame(self.root, text="🔴 신규 등록 필요 (DB에 값 없음 - X 포함)")
        new_frame.pack(fill="both", expand=True, padx=8, pady=4)
        self.tree_new = self._make_tree(new_frame, columns, headers)
        self.tree_new.tag_configure("has_x", background="#ffd6d6")

        # 하단: 기등록 (모두 Y/N)
        exist_frame = ttk.LabelFrame(self.root, text="🟢 기등록 (DB에 값 존재)")
        exist_frame.pack(fill="both", expand=True, padx=8, pady=4)
        self.tree_exist = self._make_tree(exist_frame, columns, headers)

    def _make_tree(self, parent, columns, headers):
        frm = ttk.Frame(parent)
        frm.pack(fill="both", expand=True)

        tree = ttk.Treeview(frm, columns=columns, show="headings", height=8)
        for col in columns:
            tree.heading(col, text=headers[col])
            width = 120 if col == "file" else 70
            tree.column(col, width=width, anchor="center")

        vsb = ttk.Scrollbar(frm, orient="vertical", command=tree.yview)
        hsb = ttk.Scrollbar(frm, orient="horizontal", command=tree.xview)
        tree.configure(yscrollcommand=vsb.set, xscrollcommand=hsb.set)

        tree.grid(row=0, column=0, sticky="nsew")
        vsb.grid(row=0, column=1, sticky="ns")
        hsb.grid(row=1, column=0, sticky="ew")
        frm.rowconfigure(0, weight=1)
        frm.columnconfigure(0, weight=1)
        return tree

    def _build_bottom_frame(self):
        frm = ttk.Frame(self.root)
        frm.pack(fill="x", padx=8, pady=6)
        ttk.Button(frm, text="CSV로 내보내기", command=self._export_csv).pack(side="right")

    # ---------- 이벤트 핸들러 ----------
    def _browse_repo(self):
        path = filedialog.askdirectory()
        if path:
            self.repo_path_var.set(path)

    def _run_clicked(self):
        repo_path = self.repo_path_var.get().strip()
        branch = self.branch_var.get().strip()
        from_commit = self.from_var.get().strip()
        to_commit = self.to_var.get().strip()

        if not all([repo_path, branch, from_commit, to_commit]):
            messagebox.showwarning("입력 확인", "모든 입력값을 채워주세요.")
            return

        self.run_btn.config(state="disabled")
        self.tree_new.delete(*self.tree_new.get_children())
        self.tree_exist.delete(*self.tree_exist.get_children())
        self.rows_data = []

        t = threading.Thread(
            target=self._run_analysis_thread,
            args=(repo_path, branch, from_commit, to_commit, self.scan_mode_var.get()),
            daemon=True,
        )
        t.start()

    def _run_analysis_thread(self, repo_path, branch, from_commit, to_commit, scan_mode):
        try:
            def progress_cb(idx, total, filepath):
                self.status_var.set(f"분석 중... ({idx}/{total}) {filepath}")

            rows = analyze(repo_path, branch, from_commit, to_commit, scan_mode, progress_cb)
            self.root.after(0, self._populate_results, rows)
        except Exception as e:
            self.root.after(0, lambda: messagebox.showerror("오류", str(e)))
        finally:
            self.root.after(0, lambda: self.run_btn.config(state="normal"))

    def _populate_results(self, rows):
        self.rows_data = rows
        new_count = 0
        exist_count = 0

        for r in rows:
            if r["call_type"] == "fabUse":
                values = [
                    r["file"], r["author"], "fabUse",
                    r["fabuse_value"], r["fabuse_yn"],
                    "", "",
                ] + ["" for _ in FACTORY_LIST]
                has_x = r["fabuse_yn"] == "X"
            else:
                factory_vals = [r["factory_results"].get(f, "X") for f in FACTORY_LIST]
                values = [
                    r["file"], r["author"], "fabDif",
                    "", "",
                    r["catg_cd"], r["dif_cd"],
                ] + factory_vals
                has_x = "X" in factory_vals

            if has_x:
                self.tree_new.insert("", "end", values=values, tags=("has_x",))
                new_count += 1
            else:
                self.tree_exist.insert("", "end", values=values)
                exist_count += 1

        self.status_var.set(f"완료. 신규 등록 필요 {new_count}건 / 기등록 {exist_count}건")

    def _export_csv(self):
        if not self.rows_data:
            messagebox.showinfo("안내", "내보낼 데이터가 없습니다.")
            return
        path = filedialog.asksaveasfilename(defaultextension=".csv", filetypes=[("CSV", "*.csv")])
        if not path:
            return

        header = ["구분(신규/기등록)", "파일명", "Merge개발자", "호출타입", "FabUseVal", "FabUseYn", "CatgCd", "DifCd"] + FACTORY_LIST
        with open(path, "w", newline="", encoding="utf-8-sig") as f:
            writer = csv.writer(f)
            writer.writerow(header)
            for r in self.rows_data:
                if r["call_type"] == "fabUse":
                    row_body = [r["file"], r["author"], "fabUse", r["fabuse_value"], r["fabuse_yn"], "", ""] + [""] * len(FACTORY_LIST)
                    has_x = r["fabuse_yn"] == "X"
                else:
                    factory_vals = [r["factory_results"].get(f, "X") for f in FACTORY_LIST]
                    row_body = [r["file"], r["author"], "fabDif", "", "", r["catg_cd"], r["dif_cd"]] + factory_vals
                    has_x = "X" in factory_vals
                status_label = "신규" if has_x else "기등록"
                writer.writerow([status_label] + row_body)

        messagebox.showinfo("완료", f"CSV 저장 완료:\n{path}")


if __name__ == "__main__":
    root = tk.Tk()
    app = App(root)
    root.mainloop()
