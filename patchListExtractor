    def _run_clicked(self):
        repo_path   = self.repo_path_var.get().strip()
        branch      = self.branch_var.get().strip()
        from_commit = self.from_var.get().strip()
        to_commit   = self.to_var.get().strip()

        if not all([repo_path, branch, from_commit, to_commit]):
            messagebox.showwarning("입력 확인", "모든 입력값을 채워주세요.")
            return

        use_bonsa = self.use_bonsa_var.get()
        use_wusi  = self.use_wusi_var.get()
        if not use_bonsa and not use_wusi:
            messagebox.showwarning("입력 확인", "본사 / 우시 중 하나 이상 선택해주세요.")
            return

        self.rows_data    = []
        self._new_count   = 0
        self._exist_count = 0
        self._stop_event.clear()
        self.tree_new.delete(*self.tree_new.get_children())
        self.tree_exist.delete(*self.tree_exist.get_children())
        self.run_btn.config(state="disabled")
        self.stop_btn.config(state="normal")
        self.status_var.set("분석 시작...")
        self._on_factory_toggle()

        t = threading.Thread(
            target=self._run_analysis_thread,
            args=(repo_path, branch, from_commit, to_commit,
                  self.scan_mode_var.get(), use_bonsa, use_wusi),
            daemon=True,
        )
        t.start()

    def _run_analysis_thread(self, repo_path, branch, from_commit, to_commit,
                              scan_mode, use_bonsa, use_wusi):
        try:
            def progress_cb(idx, total, label, phase=""):
                self.status_var.set(f"{phase} ({idx}/{total})  {label}")

            def row_cb(row):
                self.root.after(0, self._add_row, row)

            rows, active_factories = analyze(
                repo_path, branch, from_commit, to_commit,
                scan_mode, use_bonsa, use_wusi,
                row_cb=row_cb,
                progress_cb=progress_cb,
                stop_event=self._stop_event,
            )
            self.rows_data        = rows
            self.active_factories = active_factories
            self.root.after(0, self._on_analysis_done)

        except Exception as e:
            err_msg = str(e)
            self.root.after(0, lambda: messagebox.showerror("오류", err_msg))
        finally:
            self.root.after(0, lambda: self.run_btn.config(state="normal"))
            self.root.after(0, lambda: self.stop_btn.config(state="disabled"))

    # ── 행 추가 ────────────────────────────────────────────
    def _add_row(self, row):
        active = row["active_factories"]
        files  = row["files"]

        if row["call_type"] == "fabUse":
            has_x     = row["fabuse_yn"] == "X"
            fac_vals  = [""] * len(ALL_FACTORIES)
            def make_values(fp, auth):
                return ([fp, auth, "fabUse",
                         row["fabuse_value"], row["fabuse_yn"], "", ""]
                        + fac_vals)
        else:
            fac_vals = [
                row["factory_results"].get(f, "X") if f in active else ""
                for f in ALL_FACTORIES
            ]
            has_x = any(
                row["factory_results"].get(f, "X") == "X"
                for f in active
            )
            def make_values(fp, auth):
                return ([fp, auth, "fabDif",
                         "", "", row["catg_cd"], row["dif_cd"]]
                        + fac_vals)

        tree  = self.tree_new if has_x else self.tree_exist
        tag   = ("has_x",) if has_x else ()

        first_file, first_author = files[0]
        extra        = len(files) - 1
        display_file = f"{first_file}  (+{extra})" if extra > 0 else first_file

        parent_id = tree.insert("", "end",
                                values=make_values(display_file, first_author),
                                tags=tag,
                                open=False)

        for fp, auth in files[1:]:
            tree.insert(parent_id, "end",
                        values=make_values(fp, auth),
                        tags=("child",))

        if has_x:
            self._new_count += 1
        else:
            self._exist_count += 1

        self.status_var.set(
            f"조회 중...  신규 {self._new_count}건  /  기등록 {self._exist_count}건"
        )

    def _on_analysis_done(self):
        stopped = self._stop_event.is_set()
        prefix  = "중지됨." if stopped else "완료."
        self.status_var.set(
            f"{prefix}  신규 등록 필요 {self._new_count}건  "
            f"/  기등록 {self._exist_count}건"
        )

    # ── 엑셀 내보내기 ──────────────────────────────────────
    def _export_excel(self):
        if not self.rows_data:
            messagebox.showinfo("안내", "내보낼 데이터가 없습니다.")
            return

        path = filedialog.asksaveasfilename(
            defaultextension=".xlsx",
            filetypes=[("Excel", "*.xlsx")],
        )
        if not path:
            return

        active      = self.active_factories
        header      = (["구분", "파일명", "Merge개발자", "호출타입",
                         "FabUseVal", "FabUseYn", "CatgCd", "DifCd"] + active)
        fill_red    = PatternFill("solid", fgColor="FFD6D6")
        fill_header = PatternFill("solid", fgColor="4472C4")
        fill_child  = PatternFill("solid", fgColor="F5F5F5")
        font_header = Font(bold=True, color="FFFFFF")
        font_x      = Font(bold=True, color="CC0000")
        font_child  = Font(color="888888")
        center      = Alignment(horizontal="center", vertical="center")

        def _is_new(r):
            if r["call_type"] == "fabUse":
                return r["fabuse_yn"] == "X"
            return any(r["factory_results"].get(f, "X") == "X" for f in active)

        wb = openpyxl.Workbook()
        wb.remove(wb.active)

        for sheet_name, subset in [
            ("신규등록필요", [r for r in self.rows_data if     _is_new(r)]),
            ("기등록",       [r for r in self.rows_data if not _is_new(r)]),
        ]:
            ws = wb.create_sheet(sheet_name)
            ri = 1

            for ci, h in enumerate(header, 1):
                cell = ws.cell(row=ri, column=ci, value=h)
                cell.fill      = fill_header
                cell.font      = font_header
                cell.alignment = center
            ri += 1

            for r in subset:
                is_new = _is_new(r)
                label  = "신규" if is_new else "기등록"

                if r["call_type"] == "fabUse":
                    fvals = [""] * len(active)
                    def make_row(fp, auth):
                        return ([label, fp, auth, "fabUse",
                                 r["fabuse_value"], r["fabuse_yn"], "", ""]
                                + fvals)
                else:
                    fvals = [r["factory_results"].get(f, "X") for f in active]
                    def make_row(fp, auth):
                        return ([label, fp, auth, "fabDif",
                                 "", "", r["catg_cd"], r["dif_cd"]]
                                + fvals)

                for file_idx, (fp, auth) in enumerate(r["files"]):
                    is_child = file_idx > 0
                    for ci, val in enumerate(make_row(fp, auth), 1):
                        cell           = ws.cell(row=ri, column=ci, value=val)
                        cell.alignment = center
                        if is_child:
                            cell.fill = fill_child
                            cell.font = font_child
                        elif val == "X":
                            cell.fill = fill_red
                            cell.font = font_x
                    ri += 1

            for col in ws.columns:
                max_len = max((len(str(c.value or "")) for c in col), default=0)
                ws.column_dimensions[col[0].column_letter].width = min(max_len + 4, 40)

        wb.save(path)
        messagebox.showinfo("완료", f"엑셀 저장 완료:\n{path}")


