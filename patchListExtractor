    # ── 이벤트 핸들러 ──────────────────────────────────────
    def _browse_repo(self):
        path = filedialog.askdirectory()
        if path:
            self.repo_path_var.set(path)

    def _copy_selected(self, tree):
        """선택된 행을 탭 구분으로 클립보드에 복사"""
        selected = tree.selection()
        if not selected:
            return
        lines = []
        for item in selected:
            vals = tree.item(item, "values")
            lines.append("\t".join(str(v) for v in vals))
        self.root.clipboard_clear()
        self.root.clipboard_append("\n".join(lines))

    def _run_clicked(self):
        repo_path   = self.repo_path_var.get().strip()
        branch      = self.branch_var.get().strip()
        from_commit = self.from_var.get().strip()
        to_commit   = self.to_var.get().strip()

        if not all([repo_path, branch, from_commit, to_commit]):
            messagebox.showwarning("입력 확인", "모든 입력값을 채워주세요.")
            return

        use_bonsa = self.use_bonsa_var.get()
        use_wusi  = self.use_wusi_var.get()
        if not use_bonsa and not use_wusi:
            messagebox.showwarning("입력 확인", "본사 / 우시 중 하나 이상 선택해주세요.")
            return

        self.run_btn.config(state="disabled")
        self.status_var.set("분석 시작...")
        self.rows_data = []

        t = threading.Thread(
            target=self._run_analysis_thread,
            args=(repo_path, branch, from_commit, to_commit,
                  self.scan_mode_var.get(), use_bonsa, use_wusi),
            daemon=True,
        )
        t.start()

    def _run_analysis_thread(self, repo_path, branch, from_commit, to_commit,
                              scan_mode, use_bonsa, use_wusi):
        try:
            def progress_cb(idx, total, filepath):
                self.status_var.set(f"분석 중... ({idx}/{total}) {filepath}")

            rows, active_factories = analyze(
                repo_path, branch, from_commit, to_commit,
                scan_mode, use_bonsa, use_wusi, progress_cb
            )
            self.root.after(0, self._populate_results, rows, active_factories)
        except Exception as e:
            err_msg = str(e)
            self.root.after(0, lambda: messagebox.showerror("오류", err_msg))
        finally:
            self.root.after(0, lambda: self.run_btn.config(state="normal"))

    def _populate_results(self, rows, active_factories):
        self.rows_data        = rows
        self.active_factories = active_factories

        # 팩토리 컬럼이 바뀔 수 있으므로 트리 재생성
        self._rebuild_trees(active_factories)

        new_count = exist_count = 0

        for r in rows:
            if r["call_type"] == "fabUse":
                values = ([r["file"], r["author"], "fabUse",
                           r["fabuse_value"], r["fabuse_yn"], "", ""]
                          + [""] * len(active_factories))
                has_x = r["fabuse_yn"] == "X"
            else:
                fvals  = [r["factory_results"].get(f, "X") for f in active_factories]
                values = ([r["file"], r["author"], "fabDif",
                           "", "", r["catg_cd"], r["dif_cd"]]
                          + fvals)
                has_x = "X" in fvals

            if has_x:
                self.tree_new.insert("", "end", values=values, tags=("has_x",))
                new_count += 1
            else:
                self.tree_exist.insert("", "end", values=values)
                exist_count += 1

        self.status_var.set(
            f"완료.  신규 등록 필요 {new_count}건  /  기등록 {exist_count}건"
        )

    # ── 엑셀 내보내기 ──────────────────────────────────────
    def _export_excel(self):
        if not self.rows_data:
            messagebox.showinfo("안내", "내보낼 데이터가 없습니다.")
            return

        path = filedialog.asksaveasfilename(
            defaultextension=".xlsx",
            filetypes=[("Excel", "*.xlsx")],
        )
        if not path:
            return

        wb = openpyxl.Workbook()
        wb.remove(wb.active)  # 기본 시트 제거

        header = (["구분", "파일명", "Merge개발자", "호출타입",
                   "FabUseVal", "FabUseYn", "CatgCd", "DifCd"]
                  + self.active_factories)

        fill_red    = PatternFill("solid", fgColor="FFD6D6")
        fill_header = PatternFill("solid", fgColor="4472C4")
        font_header = Font(bold=True, color="FFFFFF")
        font_x      = Font(bold=True, color="CC0000")
        center      = Alignment(horizontal="center", vertical="center")

        for sheet_name, rows_subset in [
            ("신규등록필요", [r for r in self.rows_data if self._is_new(r)]),
            ("기등록",       [r for r in self.rows_data if not self._is_new(r)]),
        ]:
            ws = wb.create_sheet(sheet_name)

            # 헤더
            for col_idx, h in enumerate(header, 1):
                cell = ws.cell(row=1, column=col_idx, value=h)
                cell.fill      = fill_header
                cell.font      = font_header
                cell.alignment = center

            # 데이터
            for row_idx, r in enumerate(rows_subset, 2):
                if r["call_type"] == "fabUse":
                    fvals    = [""] * len(self.active_factories)
                    is_new   = r["fabuse_yn"] == "X"
                    row_data = (["신규" if is_new else "기등록",
                                 r["file"], r["author"], "fabUse",
                                 r["fabuse_value"], r["fabuse_yn"], "", ""]
                                + fvals)
                else:
                    fvals    = [r["factory_results"].get(f, "X") for f in self.active_factories]
                    is_new   = "X" in fvals
                    row_data = (["신규" if is_new else "기등록",
                                 r["file"], r["author"], "fabDif",
                                 "", "", r["catg_cd"], r["dif_cd"]]
                                + fvals)

                for col_idx, val in enumerate(row_data, 1):
                    cell = ws.cell(row=row_idx, column=col_idx, value=val)
                    cell.alignment = center
                    if val == "X":
                        cell.fill = fill_red
                        cell.font = font_x

            # 열 너비 자동 조정
            for col in ws.columns:
                max_len = max((len(str(c.value or "")) for c in col), default=0)
                ws.column_dimensions[col[0].column_letter].width = min(max_len + 4, 40)

        wb.save(path)
        messagebox.showinfo("완료", f"엑셀 저장 완료:\n{path}")

    def _is_new(self, r):
        if r["call_type"] == "fabUse":
            return r["fabuse_yn"] == "X"
        return "X" in [r["factory_results"].get(f, "X") for f in self.active_factories]


