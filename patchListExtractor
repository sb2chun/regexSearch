        self.tree_new = self._make_tree(new_frame)
        self.tree_new.tag_configure("has_x", background="#ffd6d6")
        self.tree_new.tag_configure("child", background="#fff0f0", foreground="#999999")

        exist_frame = ttk.LabelFrame(self.root, text="🟢 기등록 (DB 값 존재)  ※ 컬럼 헤더 클릭 시 해당 컬럼 전체 값 복사")
        exist_frame.pack(fill="both", expand=True, padx=8, pady=3)
        self.tree_exist = self._make_tree(exist_frame)
        self.tree_exist.tag_configure("child", background="#f5f5f5", foreground="#999999")

    def _make_tree(self, parent):
        columns = self._columns
        headers = self._headers

        frm  = ttk.Frame(parent)
        frm.pack(fill="both", expand=True)

        tree = ttk.Treeview(frm, columns=columns,
                             show="tree headings",
                             height=7,
                             selectmode="extended")

        tree.column("#0", width=24, minwidth=24, stretch=False)
        tree.heading("#0", text="")

        for col in columns:
            # 헤더 클릭 → 해당 컬럼 전체 값 복사
            tree.heading(col, text=headers[col],
                         command=lambda c=col, t=tree: self._copy_column(c, t))
            if col in ALL_FACTORIES:
                w = COL_WIDTH["factory"]
            else:
                w = COL_WIDTH.get(col, 80)
            tree.column(col, width=w, minwidth=0, anchor="center")

        vsb = ttk.Scrollbar(frm, orient="vertical",   command=tree.yview)
        hsb = ttk.Scrollbar(frm, orient="horizontal", command=tree.xview)
        tree.configure(yscrollcommand=vsb.set, xscrollcommand=hsb.set)

        tree.grid(row=0, column=0, sticky="nsew")
        vsb.grid(row=0,  column=1, sticky="ns")
        hsb.grid(row=1,  column=0, sticky="ew")
        frm.rowconfigure(0, weight=1)
        frm.columnconfigure(0, weight=1)

        # 행 선택 후 Ctrl+C → 선택 행 복사
        tree.bind("<Control-c>", lambda e, t=tree: self._copy_selected(t))

        return tree

    # ── 컬럼 전체 복사 ─────────────────────────────────────
    def _copy_column(self, col, tree):
        col_idx = self._columns.index(col)
        values  = []
        for item in tree.get_children():
            vals = tree.item(item, "values")
            if vals and col_idx < len(vals) and vals[col_idx]:
                values.append(str(vals[col_idx]))
            for child in tree.get_children(item):
                vals = tree.item(child, "values")
                if vals and col_idx < len(vals) and vals[col_idx]:
                    values.append(str(vals[col_idx]))
        if values:
            self.root.clipboard_clear()
            self.root.clipboard_append("\n".join(values))
            col_name = self._headers.get(col, col).replace(" (헤더클릭=복사)", "")
            self.status_var.set(f"[{col_name}] {len(values)}개 복사됨")
        else:
            self.status_var.set("복사할 값이 없습니다.")

    # ── 선택 행 복사 ───────────────────────────────────────
    def _copy_selected(self, tree):
        selected = tree.selection()
        if not selected:
            return
        lines = ["\t".join(str(v) for v in tree.item(i, "values"))
                 for i in selected]
        self.root.clipboard_clear()
        self.root.clipboard_append("\n".join(lines))
        self.status_var.set(f"{len(lines)}행 복사됨")

    # ── 팩토리 컬럼 숨김/표시 ──────────────────────────────
    def _on_factory_toggle(self):
        use_bonsa = self.use_bonsa_var.get()
        use_wusi  = self.use_wusi_var.get()
        for tree in (self.tree_new, self.tree_exist):
            for f in BONSA_FACTORIES:
                w = COL_WIDTH["factory"] if use_bonsa else 0
                tree.column(f, width=w, minwidth=0)
            for f in WUSI_FACTORIES:
                w = COL_WIDTH["factory"] if use_wusi else 0
                tree.column(f, width=w, minwidth=0)

